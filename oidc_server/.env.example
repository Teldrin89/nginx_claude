# Mock Entra ID — environment configuration
# Copy to .env and adjust as needed

# Port to listen on
PORT=3000

# Public base URL (used in issuer, discovery URLs, token iss claim)
BASE_URL=http://localhost:3000

# Tenant ID embedded in all OIDC URLs
# Your app must point to:  http://localhost:3000/<TENANT_ID>/v2.0/.well-known/openid-configuration
TENANT_ID=mock-tenant-id

# ──────────────────────────────────────────────────────────────────────────────
# Override users as JSON (optional — edit src/server.js USERS array instead)
# ──────────────────────────────────────────────────────────────────────────────
# MOCK_USERS=[{"id":"u1","username":"dev@company.dev","password":"Dev1!","displayName":"Dev User","givenName":"Dev","familyName":"User","email":"dev@company.dev","roles":["User"],"groups":["grp-users"],"tenantId":"mock-tenant-id","jobTitle":"Developer","department":"Eng"}]

# ──────────────────────────────────────────────────────────────────────────────
# Override clients as JSON (optional — edit src/server.js CLIENTS array instead)
# ──────────────────────────────────────────────────────────────────────────────
# MOCK_CLIENTS=[{"clientId":"my-app","clientSecret":"secret","redirectUris":["http://localhost:8080/callback"],"allowedScopes":["openid","profile","email","offline_access"]}]
