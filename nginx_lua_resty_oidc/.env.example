# .env.example
# Copy to .env and fill in real values.
# NEVER commit .env to version control.

# ── Entra ID / Azure AD ────────────────────────────────────────────────────

# Tenant ID (GUID) or "common" for multi-tenant apps
ENTRA_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# App Registration → Overview → Application (client) ID
ENTRA_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# App Registration → Certificates & secrets → Client secret → Value
ENTRA_CLIENT_SECRET=your-client-secret-value

# ── Application ────────────────────────────────────────────────────────────

# Public base URL (no trailing slash); must match the redirect URI registered
# in Entra ID: App Registration → Authentication → Redirect URIs
# e.g. https://your.domain.example.com
APP_BASE_URL=https://your.domain.example.com

# Optional: Entra ID group GUID that is required for access
# (uncomment the group check block in oidc_access.lua to enforce this)
# REQUIRED_GROUP_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Flask ──────────────────────────────────────────────────────────────────
FLASK_ENV=production
