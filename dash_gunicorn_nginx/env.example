# Dash app — OIDC configuration
# Copy to .env and adjust as needed (Docker Compose reads this automatically
# if you add `env_file: .env` to the app service, or export these manually)

# ── Mock Entra ID connection ────────────────────────────────
OIDC_BASE_URL=http://localhost:3000
# Server-side back-channel URL — set this when the IdP is not reachable
# via OIDC_BASE_URL from inside the app process (e.g. systemd services
# on the same host: use 127.0.0.1 instead of localhost to be explicit).
OIDC_INTERNAL_BASE_URL=http://127.0.0.1:3000
OIDC_TENANT_ID=mock-tenant-id
OIDC_CLIENT_ID=my-dev-app
OIDC_CLIENT_SECRET=dev-secret-change-me
OIDC_REDIRECT_URI=http://localhost:8080/callback
OIDC_SCOPE="openid profile email offline_access"
OIDC_POST_LOGOUT_REDIRECT=http://localhost:8080/

# ── Flask ────────────────────────────────────────────────────
FLASK_SECRET_KEY=change-me-to-a-random-64-char-hex-string

# ── Gunicorn ─────────────────────────────────────────────────
GUNICORN_PORT=8080
GUNICORN_WORKERS=2
GUNICORN_LOG_LEVEL=info
